{
  "name": "@ranuts/chat-ui",
  "version": "0.0.1",
  "description": "Framework-free, dependency-free chat / IM UI component — message list, streaming, and an input box. Bring your own backend.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepare": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "keywords": ["chat", "im", "chat-ui", "messages", "streaming", "ui-component"],
  "license": "MIT"
}
