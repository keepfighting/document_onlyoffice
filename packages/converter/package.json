{
  "name": "@ranuts/converter",
  "version": "0.0.1",
  "description": "In-browser Office document conversion via OnlyOffice x2t (WASM): docx / xlsx / pptx / csv / pdf, plus DOCX/PPTX media extraction.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepare": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@ranuts/shared": "workspace:*",
    "ranui": "0.2.0-alpha.0",
    "ranuts": "0.2.0-alpha.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "keywords": [
    "onlyoffice",
    "x2t",
    "wasm",
    "docx",
    "xlsx",
    "pptx",
    "pdf",
    "convert"
  ],
  "license": "MIT"
}
